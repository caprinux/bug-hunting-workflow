{
  "type": "object",
  "properties": {
    "narrative": {
      "type": "string",
      "description": "Brief progress note (1-2 sentences) for the human-readable conversation log. Always populate. Plain text, no markdown. Empty string only if you have nothing to say."
    },
    "individual_bugs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "demonstrated_chains": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bug_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "combined_impact": {
            "type": "string"
          },
          "execution_order": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "demonstrated",
              "proposed"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "informational"
            ]
          }
        },
        "required": [
          "id",
          "bug_ids",
          "description",
          "combined_impact",
          "execution_order",
          "status",
          "severity"
        ],
        "additionalProperties": false
      }
    },
    "proposed_chains": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bug_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "combined_impact": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "demonstrated",
              "proposed"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "informational"
            ]
          }
        },
        "required": [
          "id",
          "bug_ids",
          "description",
          "combined_impact",
          "status",
          "severity"
        ],
        "additionalProperties": false
      }
    },
    "rehunt_suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target_bug_class": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        },
        "required": [
          "target_bug_class",
          "reason",
          "priority"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "narrative",
    "individual_bugs",
    "demonstrated_chains",
    "proposed_chains",
    "rehunt_suggestions"
  ],
  "additionalProperties": false
}