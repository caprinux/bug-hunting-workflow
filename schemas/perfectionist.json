{
  "type": "object",
  "properties": {
    "narrative": {
      "type": "string",
      "description": "Brief progress note (1-2 sentences) for the human-readable conversation log. Always populate. Plain text, no markdown. Empty string only if you have nothing to say."
    },
    "expanded": {
      "type": "boolean"
    },
    "expanded_primitives": {
      "type": "object",
      "properties": {
        "demonstrated": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "primitive": {
                "type": "string"
              },
              "poc_file": {
                "type": "string"
              },
              "poc_code": {
                "type": "string"
              },
              "execution_result": {
                "type": "string",
                "enum": [
                  "success",
                  "failure",
                  "error",
                  "destructive_skipped"
                ]
              }
            },
            "required": [
              "primitive",
              "poc_file",
              "poc_code",
              "execution_result"
            ],
            "additionalProperties": false
          }
        },
        "theoretical": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "primitive": {
                "type": "string"
              },
              "reason_not_demonstrated": {
                "type": "string"
              }
            },
            "required": [
              "primitive",
              "reason_not_demonstrated"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "demonstrated",
        "theoretical"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "narrative",
    "expanded",
    "expanded_primitives"
  ],
  "additionalProperties": false
}