{
  "type": "object",
  "properties": {
    "narrative": {
      "type": "string",
      "description": "Brief progress note (1-2 sentences) for the human-readable conversation log. Always populate. Plain text, no markdown. Empty string only if you have nothing to say."
    },
    "deduplicated": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of bug IDs that survived deduplication"
    },
    "duplicate_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "merged_into": {
            "type": "string"
          },
          "duplicates": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "merged_into",
          "duplicates",
          "reason"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "narrative",
    "deduplicated",
    "duplicate_groups"
  ],
  "additionalProperties": false
}