{
  "type": "object",
  "properties": {
    "narrative": {
      "type": "string",
      "description": "Brief progress note (1-2 sentences) for the human-readable conversation log. Always populate. Plain text, no markdown. Empty string only if you have nothing to say."
    },
    "tagged": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "tag": {
            "type": "string",
            "enum": [
              "strong",
              "weak",
              "informational"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "informational"
            ]
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "tag",
          "severity",
          "note"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "narrative",
    "tagged"
  ],
  "additionalProperties": false
}